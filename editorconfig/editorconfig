[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true

[*.ts]
indent_style = tab
tab_width = 2
trim_trailing_whitespace = true

[*.html]
indent_style = tab
tab_width = 2

[pyproject.toml]
indent_style = space
indent_size = 4

[package.json]
indent_style = space
indent_size = 2

[webpack.config.js]
indent_style = space
indent_size = 2
